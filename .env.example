# SAP AI Core credentials (option A: individual variables)
AICORE_AUTH_URL=https://<instance>.authentication.<region>.hana.ondemand.com/oauth/token
AICORE_CLIENT_ID=your-client-id
AICORE_CLIENT_SECRET=your-client-secret
AICORE_BASE_URL=https://api.ai.<region>.cfapps.sap.hana.ondemand.com/v2
AICORE_RESOURCE_GROUP=default

# Or (option B: full service key JSON as a single line)
# AICORE_SERVICE_KEY={"clientid":"...","clientsecret":"...","url":"...","serviceurls":{"AI_API_URL":"..."}}

# Dynamic agent registry storage.
# On SAP BTP this is resolved from the bound postgresql-db service.
# Locally, point at a running PostgreSQL instance, or leave unset to
# fall back to a local SQLite file (agents_registry.db).
# DATABASE_URL=postgresql+asyncpg://user:password@localhost:5432/agents

# Optional: restrict the MCP URLs admins can register.
# Comma-separated list of URL prefixes. Default allows any *.hana.ondemand.com.
# MCP_URL_ALLOWLIST=https://my-mcp-a.cfapps.eu20-001.hana.ondemand.com,https://my-mcp-b.cfapps.eu20-001.hana.ondemand.com

# Optional: CF API restart (Restart app button). Bind a user-provided service
# named 'cf-api' instead if possible. SpaceDeveloper role required.
# CF_USERNAME=
# CF_PASSWORD=
